APP_NAME="b5hunt"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Arabic-first. Fallback to English for the global-expansion phase.
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---- Database: MySQL ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=b5hunt
DB_USERNAME=root
DB_PASSWORD=

# ---- Redis-backed runtime ----
# session / cache / queue all on Redis. Real-time via Reverb.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Use predis locally (no phpredis ext required). On the server prefer phpredis.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Laravel Reverb (WebSockets) ----
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---- Mail ----
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@b5hunt.test"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Object storage (optional) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Data ingestion (external free provider — pluggable) ----
# driver: csv (local seed for dev) | futdb | futgg  — final provider TBD
DATA_PROVIDER=csv
DATA_PLATFORM=console
# FutDB (free API key tier) — example external provider
FUTDB_BASE_URL=https://futdb.app/api
FUTDB_API_KEY=

VITE_APP_NAME="${APP_NAME}"
